#include <iostream>
#include <fstream>
#include <string>
#include <unordered_map>
#include <bitset>
using namespace std;

// Parser class, reads file, classifies commands, handles C commands
class Parser {
private:
    ifstream file;
    string currentLine;

public:
    Parser(const string& filename) {
        file.open(filename);
        if (!file.is_open()) {
            cerr << "Error opening file\n";
        }
    }

    bool hasMoreCommands() {
        return static_cast<bool>(getline(file, currentLine));
    }

    void advance() {
        while (hasMoreCommands()) {
            cleanLine(currentLine);
            if (!currentLine.empty()) {
                break;
            }
        }
    }

    string commandType() {
        if (currentLine[0] == '@') return "A_COMMAND";
        if (currentLine[0] == '(') return "L_COMMAND";
        else return "C_COMMAND";
    }

    string symbol(string command) {
        if (command == "A_COMMAND") {
            return currentLine.substr(1);
        }
        if (command == "L_COMMAND") {
            return currentLine.substr(1, currentLine.length() - 2);
        }
        return "";
    }

    string destination() {
        size_t equalPos = currentLine.find("=");
        if (equalPos != string::npos) {
            return currentLine.substr(0, equalPos);
        }
        return "";
    }

    string computation() {
        size_t equalPos = currentLine.find("=");
        size_t semicolonPos = currentLine.find(";");

        if (equalPos != string::npos) {
            return currentLine.substr(equalPos + 1, semicolonPos - equalPos - 1);
        } else if (semicolonPos != string::npos) {
            return currentLine.substr(0, semicolonPos);
        }
        return "";
    }

    string jump() {
        size_t semicolonPos = currentLine.find(";");
        if (semicolonPos != string::npos) {
            return currentLine.substr(semicolonPos + 1);
        }
        return "";
    }

private:
    void cleanLine(string& line) {
        // Remove comments and extra whitespace
        size_t commentPos = line.find("//");
        if (commentPos != string::npos) {
            line = line.substr(0, commentPos);
        }
        line.erase(0, line.find_first_not_of(" \t"));  // Trim leading whitespace
    }
};

class Code {
private:
    string dest;
    string comp;
    string jump;

    static const unordered_map<string, string> destDict;
    static const unordered_map<string, string> compDict;
    static const unordered_map<string, string> jumpDict;

public:
    Code(const string& dest, const string& comp, const string& jump)
        : dest(dest), comp(comp), jump(jump) {}

    string toBinary() {
        string binary = "111";
        binary += compDict.at(comp);
        binary += destDict.at(dest);
        binary += jumpDict.at(jump);

        return binary;
    }
};

