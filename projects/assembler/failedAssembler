unordered_map<string, int> createPredefinedSymbols() {
    unordered_map<string, int> predefinedSymbols;

    // Initialize R0 to R15 (addresses 0 to 15 in decimal)
    for (int i = 0; i <= 15; ++i) {
        predefinedSymbols["R" + to_string(i)] = i;
    }

    // Initialize predefined symbols (SP, LCL, ARG, THIS, THAT, SCREEN, KBD)
    predefinedSymbols["SP"] = 0;    // Address 0
    predefinedSymbols["LCL"] = 1;   // Address 1
    predefinedSymbols["ARG"] = 2;   // Address 2
    predefinedSymbols["THIS"] = 3;  // Address 3
    predefinedSymbols["THAT"] = 4;  // Address 4
    predefinedSymbols["SCREEN"] = 16384;  // Address 16384 (decimal)
    predefinedSymbols["KBD"] = 24576;     // Address 24576 (decimal)

    return predefinedSymbols;
}

class SymbolTable {
private:
    unordered_map<string, int> table;

public:
    SymbolTable(const unordered_map<string, int>& predefinedSymbols) {
        for (const auto& symbol : predefinedSymbols) {
            table[symbol.first] = symbol.second;
        }
    }

    void addEntry(const string& symbol, int address) {
        table[symbol] = address;
    }

    bool contains(const string& symbol) {
        return table.find(symbol) != table.end();
    }

    int getAddress(const string& symbol) {
        if (contains(symbol)) {
            return table[symbol];
        }
        return -1;  // Return -1 if the symbol doesn't exist
    }
};

int main(int argc, char* argv[]) {
    // Check if input file is provided as argument
    if (argc < 2) {
        cerr << "Usage: HackAssembler <input_file>" << endl;
        return 1;
    }

    // Extract input file name from command-line argument
    string inputFile = argv[1];
    string outputFile = inputFile.substr(0, inputFile.find_last_of(".")) + ".hack";  // Default output file

    // Initialize the predefined symbol table
    unordered_map<string, int> predefinedSymbols = createPredefinedSymbols();
    SymbolTable symbolTable(predefinedSymbols);

    // Create a parser for the Hack assembly file
    Parser parser(inputFile);

    // Pass 1: Collect labels
    int currentAddress = 16; // Start from address 16 for variables
    while (parser.hasMoreCommands()) {
        parser.advance();
        if (parser.commandType() == "L_COMMAND") {
            string label = parser.symbol("L_COMMAND");
            symbolTable.addEntry(label, currentAddress);
        } else {
            ++currentAddress;  // Increment address for A or C command
        }
    }

    // Pass 2: Handle A and C commands
    parser = Parser(inputFile);  // Reinitialize parser for second pass
    ofstream outFile(outputFile);
    while (parser.hasMoreCommands()) {
        parser.advance();
        if (parser.commandType() == "A_COMMAND") {
            string symbol = parser.symbol("A_COMMAND");
            int address;

            // Check if it's a number or symbol
            if (isdigit(symbol[0])) {
                address = stoi(symbol);  // Convert to int if it's a number
            } else {
                // Look up or add symbol to the table
                if (!symbolTable.contains(symbol)) {
                    symbolTable.addEntry(symbol, currentAddress++);
                }
                address = symbolTable.getAddress(symbol);
            }

            // Convert the address to a 16-bit binary string
            bitset<16> binaryAddress(address);
            outFile << binaryAddress.to_string() << endl;
        } else if (parser.commandType() == "C_COMMAND") {
            // Process C command: Convert to binary
            string dest = parser.destination();
            string comp = parser.computation();
            string jump = parser.jump();
            Code code(dest, comp, jump);
            outFile << code.toBinary() << endl;
        }
    }

    outFile.close(); // Close the output file when done
    return 0;
}

